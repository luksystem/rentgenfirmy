# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local instructions (not for repo)
/instrukcje-zapier-klient.txt

# nested clone (referencja OpenAPI Loxone)
/LoxoneSwagger/.git/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pdf.js worker — kopiowany z node_modules przez `postinstall` (scripts/copy-pdf-worker.mjs)
/public/pdf.worker.min.mjs

# SRI — oficjalne pliki zrodlowe KE (T&C zabraniaja redystrybucji; hashe w import-manifest.json)
/store/sri/*.xlsx
/store/sri/*.pdf
/store/sri/raw/

# Python cache (skrypty SRI)
__pycache__/
*.pyc

# Core Orchestrator — staging i cache buildu (artefakty w generated/<version>/ sa commitowane)
/generated/.staging/
/generated/.cache/
