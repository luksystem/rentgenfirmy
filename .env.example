NEXT_PUBLIC_SUPABASE_URL=https://twoj-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=twoj-anon-key
SUPABASE_SERVICE_ROLE_KEY=twoj-service-role-key
CLIENTS_API_SECRET=twoj-tajny-klucz-api-dla-zapier
# Cloudflare Turnstile (publiczny kreator /zgloszenie) — https://dash.cloudflare.com/
# Klucze testowe Cloudflare (zawsze przechodzą w dev):
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Używany przez /api/cron/telemetry-sync (wołany z Supabase pg_cron co 5 min)
CRON_SECRET=
# 32 bajty w base64 — wygeneruj: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=
# ChatGPT — generowanie tasków Kanban z wiadomości klienta (tylko serwer)
OPENAI_API_KEY=
# opcjonalnie, domyślnie gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Resend — maile (zgłoszenia serwisowe, ustaleń z klientem)
# Klucz API: https://resend.com/api-keys
# Lokalnie: skopiuj do .env.local w katalogu projektu (obok package.json)
# Produkcja (Vercel): Project → Settings → Environment Variables
RESEND_API_KEY=
EMAIL_FROM=LUKSYSTEM Serwis <serwis@luksystem.pl>
# Publiczny URL aplikacji — linki w mailach (oferty, ustaleń, wątki zgłoszeń)
# Lokalnie: http://localhost:3000  |  Produkcja: https://twoja-domena.pl
NEXT_PUBLIC_APP_URL=http://localhost:3000
# SMS — SMSAPI.pl (tylko serwer, nigdy w frontendzie)
SMS_PROVIDER=smsapi
SMSAPI_TOKEN=
SMSAPI_FROM=Luksystem
SMS_TEST_PHONE=
# 1 = tryb testowy SMSAPI (bez wysyłki i opłat), domyślnie włączony poza production
SMSAPI_TEST_MODE=1
# opcjonalnie — weryfikacja webhooka statusów (?secret=... lub nagłówek x-sms-webhook-secret)
SMS_WEBHOOK_SECRET=
# Google Calendar — konto serwisowe (Moja praca / Dostępność: wpis urlopu całodniowego)
# 1. Google Cloud Console → nowy projekt → API i usługi → włącz "Google Calendar API"
# 2. Utwórz konto serwisowe (Service Account) → wygeneruj klucz JSON
# 3. W Google Calendar (kalendarz firmowy) udostępnij kalendarz temu kontu serwisowemu
#    z uprawnieniem "Wprowadzanie zmian w wydarzeniach"
# 4. GOOGLE_CALENDAR_CLIENT_EMAIL = pole "client_email" z pliku JSON
# 5. GOOGLE_CALENDAR_PRIVATE_KEY = pole "private_key" z pliku JSON (zachowaj \n w wartości)
# 6. GOOGLE_CALENDAR_ID = adres kalendarza (Ustawienia kalendarza → "ID kalendarza",
#    np. abc123@group.calendar.google.com lub adres e-mail konta Google)
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
